{
  "name": "@tokenparty/tokenparty",
  "version": "0.0.15",
  "description": "Self-hosted AI gateway — route, observe, and control your LLM API traffic. OpenAI ↔ Anthropic protocol translation, cost-based smart routing, per-user budgets, and a built-in dashboard. Zero dependencies.",
  "type": "module",
  "bin": {
    "tokenparty": "dist/cli.js"
  },
  "files": [
    "dist/",
    "dashboard/"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:publish": "tsc && pnpm --filter @tokenparty/dashboard build && rm -rf dashboard && cp -r ../dashboard/dist dashboard",
    "start": "node dist/index.js"
  },
  "keywords": [
    "ai", "proxy", "gateway", "api-gateway", "llm", "openai", "anthropic", "claude", "gpt", 
    "reverse-proxy", "protocol-translation", "token-management", "cost-tracking", 
    "self-hosted", "dashboard", "budget", "routing", "sqlite"
  ],
  "author": "Zhou Zhengchang <zhiye1@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Jasonbroker/TokenParty",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jasonbroker/TokenParty.git"
  },
  "bugs": {
    "url": "https://github.com/Jasonbroker/TokenParty/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0",
    "nanoid": "^5.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
