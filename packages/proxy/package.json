{
  "name": "@zhouzhengchang/token-party",
  "version": "0.0.3",
  "description": "AI API reverse proxy gateway with token management, protocol conversion, and built-in dashboard",
  "type": "module",
  "bin": {
    "tokenparty": "dist/cli.js"
  },
  "files": [
    "dist/",
    "dashboard/",
    "config.example.yaml"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:publish": "tsc && pnpm --filter @tokenparty/dashboard build && rm -rf dashboard && cp -r ../dashboard/dist dashboard",
    "start": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "proxy",
    "openai",
    "anthropic",
    "api-gateway",
    "token-management"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0",
    "nanoid": "^5.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
